---
// Static dock with buttons for each app
---

<div id="dock" class="fixed bottom-6 left-6 flex gap-3 z-30">
  <button
    class="dock-btn px-4 py-2 rounded-lg bg-spark-black/90 border-2 border-spark-teal hover:border-spark-chartreuse hover:bg-spark-teal/20 text-spark-eggshell font-sans transition-all"
    data-open="bounties"
  >
    💰 Bounties
  </button>
  <button
    class="dock-btn px-4 py-2 rounded-lg bg-spark-black/90 border-2 border-spark-teal hover:border-spark-chartreuse hover:bg-spark-teal/20 text-spark-eggshell font-sans transition-all"
    data-open="about"
  >
    ℹ️ Info
  </button>
  <button
    class="dock-btn px-4 py-2 rounded-lg bg-spark-black/90 border-2 border-spark-teal hover:border-spark-chartreuse hover:bg-spark-teal/20 text-spark-eggshell font-sans transition-all"
    data-open="events"
  >
    📅 Events
  </button>
  <a
    href="/hall-of-fame"
    class="dock-hof px-4 py-2 rounded-lg font-sans transition-all"
    style="background:rgba(18,17,12,0.9);border:2px solid rgba(201,162,39,0.55);color:#e8c848;"
  >
    🏆 Hall of Fame
  </a>
</div>

<style>
  .dock-hof:hover {
    border-color: #c9a227 !important;
    background: rgba(201,162,39,0.12) !important;
  }
</style>
