---
// Static dock with buttons for each app
---

<div id="dock" class="fixed bottom-5 left-5 right-5 flex flex-wrap gap-2 z-30">
  <button
    class="dock-btn group flex items-center gap-2 px-3 py-2 bg-spark-black border border-spark-teal/40 hover:border-spark-chartreuse text-spark-teal/80 hover:text-spark-chartreuse font-mono text-xs uppercase tracking-widest transition-all"
    data-open="bounties"
  >
    <span class="text-spark-teal/55 group-hover:text-spark-chartreuse/50 transition-colors">[</span>
    <span>💰 Bounties</span>
    <span class="text-spark-teal/55 group-hover:text-spark-chartreuse/50 transition-colors">]</span>
  </button>
  <button
    class="dock-btn group flex items-center gap-2 px-3 py-2 bg-spark-black border border-spark-teal/40 hover:border-spark-chartreuse text-spark-teal/80 hover:text-spark-chartreuse font-mono text-xs uppercase tracking-widest transition-all"
    data-open="about"
  >
    <span class="text-spark-teal/55 group-hover:text-spark-chartreuse/50 transition-colors">[</span>
    <span>ℹ️ Info</span>
    <span class="text-spark-teal/55 group-hover:text-spark-chartreuse/50 transition-colors">]</span>
  </button>
  <button
    class="dock-btn group flex items-center gap-2 px-3 py-2 bg-spark-black border border-spark-teal/40 hover:border-spark-chartreuse text-spark-teal/80 hover:text-spark-chartreuse font-mono text-xs uppercase tracking-widest transition-all"
    data-open="events"
  >
    <span class="text-spark-teal/55 group-hover:text-spark-chartreuse/50 transition-colors">[</span>
    <span>📅 Events</span>
    <span class="text-spark-teal/55 group-hover:text-spark-chartreuse/50 transition-colors">]</span>
  </button>
  <a
    href="/hall-of-fame"
    class="dock-hof group flex items-center gap-2 px-3 py-2 bg-spark-black border font-mono text-xs uppercase tracking-widest transition-all"
  >
    <span class="dock-bracket transition-colors">[</span>
    <span>🏆 Hall of Fame</span>
    <span class="dock-bracket transition-colors">]</span>
  </a>
</div>

<style>
  .dock-hof {
    border-color: rgba(201,162,39,0.3);
    color: rgba(201,162,39,0.8);
  }
  .dock-hof .dock-bracket {
    color: rgba(201,162,39,0.25);
  }
  .dock-hof:hover {
    border-color: #c9a227;
    color: #e8c848;
  }
  .dock-hof:hover .dock-bracket {
    color: rgba(201,162,39,0.5);
  }
  @media (max-width: 767px) {
    .dock-btn, .dock-hof {
      min-height: 44px;
      padding: 0.5rem 0.75rem;
      font-size: 0.7rem;
    }
  }
</style>
