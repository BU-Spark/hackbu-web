---
import { StatusBar } from './StatusBar';

interface Props {
  events?: { title: string; when: string }[];
}

const { events = [] } = Astro.props;
---

<header class="fixed top-0 left-0 right-0 h-12 bg-spark-black border-b border-spark-teal/20 z-40 flex items-center justify-between px-5" style="backdrop-filter: blur(8px);">
  <div class="flex items-center gap-3">
    <img src="/hackbu-logo.png" alt="HackBU Logo" class="h-6 opacity-90 hackbu-logo" />
    <div class="flex items-center gap-1.5">
      <span class="font-mono text-spark-teal/40 text-xs select-none">&gt;_</span>
      <span class="font-display text-lg tracking-wider text-spark-eggshell glitch-text">HackBU OS</span>
    </div>
  </div>

  <div class="flex-1 flex justify-end mr-4">
    <StatusBar client:load events={events} />
  </div>

  <div class="flex items-center gap-2">
    <button
      id="themeToggle"
      class="w-7 h-7 flex items-center justify-center border border-spark-teal/20 hover:border-spark-teal/50 text-spark-teal/50 hover:text-spark-teal font-mono text-xs transition-all"
      aria-label="Toggle light/dark mode"
      title="Toggle light/dark mode"
    >
      <span id="theme-icon-sun" class="hidden">☀</span>
      <span id="theme-icon-moon">☽</span>
    </button>
    <button
      id="helpButton"
      class="w-7 h-7 flex items-center justify-center border border-spark-teal/20 hover:border-spark-teal/50 text-spark-teal/50 hover:text-spark-teal font-mono text-xs transition-all"
      aria-label="Help"
    >
      ?
    </button>
    <button
      id="terminalToggle"
      class="px-3 h-7 bg-spark-chartreuse text-spark-black font-mono font-bold text-xs hover:bg-spark-chartreuse/85 transition-all terminal-flash"
      aria-label="Toggle terminal"
    >
      `
    </button>
  </div>
</header>

<style>
  @keyframes flash {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.6; }
  }
  .terminal-flash {
    animation: flash 1.2s ease-in-out 5;
  }
</style>
