---
import { getCollection } from "astro:content";
import { marked } from "marked";
const bountyEntries = await getCollection("bounties");
const bounties = bountyEntries.map((entry) => ({
  title: entry.data.title,
  slug: entry.slug,
  difficulty: entry.data.difficulty,
  prize: entry.data.prize,
  deadline: entry.data.deadline,
  tags: entry.data.tags,
  status: entry.data.status,
  descriptionHtml: marked.parse(entry.body || '') as string,
  docLink: entry.data.docLink || "",
  featured: entry.data.featured || false,
  winner: entry.data.winner || "",
  winnerSubmission: entry.data.winnerSubmission || "",
}));
import projects from "../data/projects.json";
import leaderboard from "../data/leaderboard.json";
import events from "../data/events.json";

import Desktop from "../components/Desktop.astro";
const bgImages = [
  '/backgrounds/bg-1.jpg',
  '/backgrounds/bg-2.jpg',
  '/backgrounds/bg-5.jpg',
  '/backgrounds/bg-6.jpg',
  '/backgrounds/bg-7.jpg',
  '/backgrounds/bg-8.jpg',
  '/backgrounds/bg-9.jpg',
  '/backgrounds/bg-10.jpg',
  '/backgrounds/bg-11.jpg',
];
const bootBg = bgImages[Math.floor(Math.random() * bgImages.length)];
import Topbar from "../components/Topbar.astro";
import Dock from "../components/Dock.astro";
import { WindowManager } from "../components/WindowManager";
import { MobileOS } from "../components/MobileOS";
import "../styles/global.css";

// Compute dynamic bounty stats at build time
const openBounties = bounties.filter((b: any) => b.status === 'open');
const openCount = openBounties.length;
const totalPrize = openBounties.reduce((sum: number, b: any) => sum + (b.prize || 0), 0);
const formattedPrize = `$${totalPrize.toLocaleString('en-US')}`;

// Find next upcoming event
const now = new Date();
const currentYear = now.getFullYear();
function parseEventDate(when: string): Date | null {
  const d = new Date(`${when}, ${currentYear}`);
  return isNaN(d.getTime()) ? null : d;
}
const upcomingEvents = events
  .map((e: any) => ({ ...e, _date: parseEventDate(e.when) }))
  .filter((e: any) => e._date && e._date >= now)
  .sort((a: any, b: any) => a._date - b._date);
const nextEvent = upcomingEvents[0];
const nextEventStr = nextEvent ? `${nextEvent.title} (${nextEvent.when})` : 'No upcoming events';

// Build MOTD with fixed-width lines (40 inner chars between ║ and ║)
const W = 40;
function pad(text: string, width: number): string {
  // Strip emojis to count only ASCII/box-drawing display width
  const stripped = text.replace(/\p{Emoji_Presentation}|\p{Extended_Pictographic}/gu, '');
  // Each emoji we removed takes 2 display columns
  const emojiCount = (text.match(/\p{Emoji_Presentation}|\p{Extended_Pictographic}/gu) || []).length;
  const displayLen = stripped.length + (emojiCount * 2);
  const needed = width - displayLen;
  return needed > 0 ? text + ' '.repeat(needed) : text;
}
function line(text: string): string {
  return `║${pad(text, W)}║`;
}
const bountyLine = `  * ${openCount} open bounties - ${formattedPrize} in prizes`;
const eventLine = `  > Next: ${nextEventStr}`;

// Compute next Wednesday 4pm for Innovation Hours
function getNextWedLabel(): string {
  const day = now.getDay();
  let daysUntilWed = (3 - day + 7) % 7;
  if (daysUntilWed === 0 && now.getHours() >= 18) daysUntilWed = 7;
  if (daysUntilWed === 0) return 'TODAY 4-6pm';
  if (daysUntilWed === 1) return 'TOMORROW 4-6pm';
  return `in ${daysUntilWed}d (Wed 4-6pm)`;
}
const innovLine = `  > Innovation Hours: ${getNextWedLabel()}`;

const motdContent = [
  `╔${'═'.repeat(W)}╗`,
  line('  Welcome to HackBU OS v1.0'),
  line('  Message of the Day'),
  `╠${'═'.repeat(W)}╣`,
  line(''),
  line(bountyLine),
  line(eventLine),
  line(innovLine),
  line(''),
  line('  Tip: Windows are draggable!'),
  line(''),
  line('  Type `apps` or use dock below'),
  `╚${'═'.repeat(W)}╝`,
].join('\n');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HackBU OS — Coding Bounties by BU Spark!</title>
    <meta name="description" content="HackBU OS is BU Spark!'s bounty board — browse open coding challenges, win prizes, and build real projects with the Boston University tech community." />
    <meta property="og:title" content="HackBU OS — Coding Bounties by BU Spark!" />
    <meta property="og:description" content="Browse open coding challenges, win prizes, and build real projects with the BU tech community." />
    <meta property="og:image" content="https://hackbu.dev/hackbu-logo.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="HackBU OS — Coding Bounties by BU Spark!" />
    <meta name="twitter:description" content="Browse open coding challenges, win prizes, and build real projects with the BU tech community." />
    <meta name="twitter:image" content="https://hackbu.dev/hackbu-logo.png" />
    <script is:inline>
      // Theme init — runs before paint to prevent flash
      (function() {
        var stored = localStorage.getItem('hackbu-theme');
        var theme = stored || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <script defer src="https://cloud.umami.is/script.js" data-website-id="6268acbc-ec7d-467c-82e3-a2719f9e0967"></script>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <!-- Boot Screen (new CRT style) -->
    <!-- To switch to classic style: change data-boot-style="new" to data-boot-style="classic" -->
    <div
      id="boot"
      data-boot-style="new"
      class="fixed inset-0 z-50 flex scanlines bg-spark-black"
    >
      <!-- CRT vignette -->
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at center, transparent 55%, rgba(0,0,0,0.75) 100%);"></div>

      <!-- NEW STYLE: OS window popup -->
      <div id="boot-new" class="relative z-10 w-full h-full flex items-center justify-center">
        <div class="bg-spark-black border border-spark-chartreuse w-full max-w-xl mx-4 sm:mx-0" style="box-shadow: 0 0 0 1px rgba(191,241,60,0.25), 0 0 20px rgba(191,241,60,0.12), 0 16px 48px rgba(0,0,0,0.85);">
          <!-- Title bar -->
          <div class="px-3 py-2.5 flex items-center justify-between border-b border-spark-chartreuse/40 bg-spark-black select-none">
            <div class="flex items-center gap-2.5">
              <div class="w-px h-4 bg-spark-chartreuse"></div>
              <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-spark-chartreuse">HACKBU OS — BOOT</span>
            </div>
            <div class="flex gap-1.5 items-center">
              <div class="w-3.5 h-3.5 bg-[#FFBD2E]"></div>
              <div class="w-3.5 h-3.5 bg-[#28CA42]"></div>
              <div class="w-3.5 h-3.5 bg-[#FF5F57]"></div>
            </div>
          </div>
          <!-- Content -->
          <div class="p-4 sm:p-6 scanlines">
            <div class="font-display text-2xl sm:text-4xl text-spark-chartreuse tracking-widest mb-1" style="text-shadow: 0 0 24px rgba(191,241,60,0.45), 0 0 48px rgba(191,241,60,0.15);">HACKBU OS</div>
            <div class="font-mono text-spark-teal/75 text-xs uppercase tracking-[0.4em] mb-6">v1.0 — BU Spark!</div>
            <pre id="bootlog" class="font-mono text-spark-chartreuse text-xs leading-relaxed whitespace-pre-wrap"></pre>
            <span id="bootcursor" class="inline-block w-2 h-3.5 bg-spark-chartreuse boot-cursor align-middle ml-0.5"></span>
            <div class="mt-6 font-mono text-spark-teal/60 text-[10px] uppercase tracking-[0.35em]">press any key to continue</div>
          </div>
        </div>
      </div>

      <!-- CLASSIC STYLE (hidden by default) -->
      <div id="boot-classic" class="relative z-10 hidden">
        <pre id="bootlog-classic" class="font-mono text-spark-chartreuse text-sm"></pre>
      </div>
    </div>

    <div class="hidden md:block">
      <Topbar events={events} />

      <Desktop>
        <WindowManager
          client:load
          bounties={bounties}
          projects={projects}
          leaderboard={leaderboard}
          events={events}
          motd={motdContent}
        />
      </Desktop>

      <Dock />
    </div>

    <div class="md:hidden">
      <MobileOS
        client:load
        bounties={bounties}
        projects={projects}
        leaderboard={leaderboard}
        events={events}
        motd={motdContent}
      />
    </div>

    <script>
      // Boot animation
      const boot = document.getElementById("boot") as HTMLElement;
      const isMobile = window.innerWidth < 768;

      // Mobile: skip boot on return visits
      if (isMobile && localStorage.getItem('hackbu-mobile-booted')) {
        if (boot) boot.style.display = 'none';
      }

      const isClassic = boot?.dataset.bootStyle === 'classic';

      const newLines = [
        "[ OK ] initializing kernel modules ...",
        "[ OK ] mounting bu_network filesystem ...",
        "[ OK ] loading display drivers ...",
        "[ OK ] starting window compositor ...",
        "[ OK ] hacking BU databases ...",
        "[ OK ] loading bounty registry ...",
        "",
        "  HACKBU OS v1.0 ready.",
        "  press \` for terminal or click below",
      ];
      const classicLines = [
        "> initializing HackBuOS v1.0 …",
        "> connecting to bu_network …",
        "> loading skyline assets …",
        "> Press \` for terminal or use dock below",
        "> ready.",
      ];

      const lines = isClassic ? classicLines : newLines;
      const bootlog = isClassic
        ? document.getElementById("bootlog-classic")
        : document.getElementById("bootlog");
      const bootcursor = document.getElementById("bootcursor");

      if (isClassic) {
        document.getElementById("boot-new")?.classList.add("hidden");
        document.getElementById("boot-classic")?.classList.remove("hidden");
      }

      let i = 0;
      const interval = isMobile ? 180 : (isClassic ? 350 : 280);
      const bootInterval = setInterval(() => {
        if (i < lines.length) {
          bootlog!.textContent += lines[i] + "\n";
          i++;
        } else {
          clearInterval(bootInterval);
          if (bootcursor) bootcursor.style.display = 'none';
        }
      }, interval);

      // Skip boot if ?open= param is present
      const urlParams = new URLSearchParams(window.location.search);
      const autoOpen = urlParams.get('open');
      if (autoOpen && boot) {
        boot.style.display = 'none';
        clearInterval(bootInterval);
        window.dispatchEvent(new CustomEvent('openWindow', { detail: autoOpen }));
      }

      // Skip boot if Netlify Identity token is in the URL hash
      if (boot && window.location.hash.match(/^#(invite_token|recovery_token|confirmation_token)=/)) {
        boot.style.display = 'none';
        clearInterval(bootInterval);
      }

      // Skip boot on click
      let bootDismissed = false;
      const dismissBoot = (method: string) => {
        if (!boot || bootDismissed) return;
        bootDismissed = true;
        boot.style.display = "none";
        if (isMobile) localStorage.setItem('hackbu-mobile-booted', '1');
        if (typeof umami !== 'undefined') umami.track('boot-skip', { method });
      };
      boot!.addEventListener("click", (e) => {
        e.stopPropagation();
        dismissBoot("click");
      });

      // Wire up dock buttons
      document.querySelectorAll(".dock-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const app = btn.getAttribute("data-open");
          window.dispatchEvent(new CustomEvent("openWindow", { detail: app }));
        });
      });

      // Terminal toggle
      document
        .getElementById("terminalToggle")
        ?.addEventListener("click", () => {
          window.dispatchEvent(new Event("toggleTerminal"));
        });

      // Help button
      document.getElementById("helpButton")?.addEventListener("click", () => {
        window.dispatchEvent(
          new CustomEvent("openTerminalWithCommand", { detail: "help" })
        );
      });

      // Backtick key
      document.addEventListener("keydown", (e) => {
        if (e.key === "`") {
          e.preventDefault();
          window.dispatchEvent(new Event("toggleTerminal"));
        }
      });

      // Theme toggle
      const themeToggle = document.getElementById("themeToggle");
      const sunIcon = document.getElementById("theme-icon-sun");
      const moonIcon = document.getElementById("theme-icon-moon");
      const themeLabel = document.getElementById("theme-label");
      function updateThemeIcons() {
        const current = document.documentElement.getAttribute("data-theme");
        if (current === "light") {
          sunIcon?.classList.remove("hidden");
          moonIcon?.classList.add("hidden");
          if (themeLabel) themeLabel.textContent = "Dark";
        } else {
          sunIcon?.classList.add("hidden");
          moonIcon?.classList.remove("hidden");
          if (themeLabel) themeLabel.textContent = "Light";
        }
      }
      updateThemeIcons();
      themeToggle?.addEventListener("click", () => {
        const current = document.documentElement.getAttribute("data-theme");
        const next = current === "light" ? "dark" : "light";
        document.documentElement.setAttribute("data-theme", next);
        localStorage.setItem("hackbu-theme", next);
        updateThemeIcons();
        if (typeof umami !== 'undefined') umami.track('theme-toggle', { theme: next });
      });
      // Listen for OS preference changes
      window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
        if (!localStorage.getItem("hackbu-theme")) {
          document.documentElement.setAttribute("data-theme", e.matches ? "dark" : "light");
          updateThemeIcons();
        }
      });

      // Hide boot on any interaction (only after animation finishes)
      const hideBootOnInteraction = () => {
        dismissBoot("interaction");
        document.removeEventListener("click", hideBootOnInteraction);
        document.removeEventListener("keydown", hideBootOnInteraction);
      };

      const totalDuration = lines.length * interval + 300;
      setTimeout(() => {
        document.addEventListener("click", hideBootOnInteraction);
        document.addEventListener("keydown", hideBootOnInteraction);
      }, totalDuration);
    </script>
    <script is:inline>
      // Netlify Identity redirect: after login, Identity redirects to / with a token fragment
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", function(user) {
          if (!user) {
            window.netlifyIdentity.on("login", function() {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
  </body>
</html>
