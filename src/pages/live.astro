---
import events from "../data/events.json";
import "../styles/global.css";

const streamEvent = (events as any[]).find((e) => e.streamUrl);
const streamTime: string = streamEvent?.when || "Check Discord for schedule";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HackBU Live — Off Air</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
    <style>
      :root {
        --black: #12110C;
        --chartreuse: #BFF13C;
        --orange: #FF572D;
        --teal: #06B1A2;
        --eggshell: #D9EADF;
        --gold: #c9a227;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: var(--black);
        color: var(--eggshell);
        font-family: 'Share Tech Mono', monospace;
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* CRT scanlines */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(0,0,0,0.08) 2px,
          rgba(0,0,0,0.08) 4px
        );
        pointer-events: none;
        z-index: 1000;
      }

      /* Static noise overlay */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 999;
        opacity: 0.4;
      }

      /* SMPTE color bars */
      .smpte-bars {
        width: 100%;
        height: 6px;
        display: flex;
        flex-shrink: 0;
      }
      .smpte-bars span {
        flex: 1;
        display: block;
      }

      @keyframes pulse-off {
        0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(255,87,45,.6); }
        50% { opacity: 0.25; box-shadow: none; }
      }

      @keyframes pulse-standby {
        0%, 100% { opacity: 1; box-shadow: 0 0 10px rgba(191,241,60,.5); }
        50% { opacity: 0.4; box-shadow: 0 0 4px rgba(191,241,60,.2); }
      }

      @keyframes static-flicker {
        0%   { opacity: 1; }
        8%   { opacity: .94; }
        9%   { opacity: 1; }
        60%  { opacity: 1; }
        61%  { opacity: .9; transform: translateX(2px); }
        62%  { opacity: 1; transform: translateX(0); }
        100% { opacity: 1; }
      }

      @keyframes scanline-sweep {
        0%   { transform: translateY(-100%); }
        100% { transform: translateY(100vh); }
      }

      .scanline-sweep {
        position: fixed;
        left: 0; right: 0;
        height: 60px;
        background: linear-gradient(to bottom, transparent, rgba(191,241,60,.018), transparent);
        animation: scanline-sweep 7s linear infinite;
        pointer-events: none;
        z-index: 998;
      }

      @keyframes blink-cursor {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }

      .cursor { animation: blink-cursor 1s step-end infinite; }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(18px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .anim-1 { opacity: 0; animation: fadeUp .5s ease .1s forwards; }
      .anim-2 { opacity: 0; animation: fadeUp .5s ease .25s forwards; }
      .anim-3 { opacity: 0; animation: fadeUp .5s ease .4s forwards; }
      .anim-4 { opacity: 0; animation: fadeUp .5s ease .55s forwards; }
      .anim-5 { opacity: 0; animation: fadeUp .5s ease .7s forwards; }

      .off-air-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid rgba(255,87,45,.4);
        padding: 6px 14px 6px 10px;
        background: rgba(255,87,45,.06);
      }
      .off-air-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--orange);
        animation: pulse-off 2s ease-in-out infinite;
      }

      .signal-title {
        font-family: 'Bebas Neue', system-ui, sans-serif;
        font-size: clamp(5rem, 18vw, 13rem);
        line-height: 0.88;
        letter-spacing: -0.01em;
        color: var(--eggshell);
        animation: static-flicker 12s ease-in-out infinite;
      }

      .signal-sub {
        font-family: 'Bebas Neue', system-ui, sans-serif;
        font-size: clamp(1.5rem, 5vw, 3.5rem);
        letter-spacing: 0.08em;
        color: rgba(217,234,223,.18);
      }

      .broadcast-panel {
        border: 1px solid rgba(6,177,162,.15);
        background: rgba(6,177,162,.03);
        position: relative;
        overflow: hidden;
      }
      .broadcast-panel::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(6,177,162,.4), transparent);
      }

      .show-row {
        border-bottom: 1px solid rgba(217,234,223,.05);
        padding: 14px 0;
        display: flex;
        align-items: flex-start;
        gap: 16px;
      }
      .show-row:last-child { border-bottom: none; padding-bottom: 0; }

      .show-type {
        font-size: 9px;
        letter-spacing: .3em;
        text-transform: uppercase;
        padding: 2px 8px;
        border: 1px solid;
        flex-shrink: 0;
        margin-top: 2px;
      }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--chartreuse);
        color: var(--black);
        font-family: 'Share Tech Mono', monospace;
        font-size: 13px;
        letter-spacing: .12em;
        text-transform: uppercase;
        text-decoration: none;
        padding: 12px 28px;
        font-weight: 700;
        transition: background .2s, transform .15s;
      }
      .btn-primary:hover { background: rgba(191,241,60,.85); transform: translateY(-1px); }

      .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid rgba(217,234,223,.2);
        color: rgba(217,234,223,.5);
        font-family: 'Share Tech Mono', monospace;
        font-size: 12px;
        letter-spacing: .1em;
        text-transform: uppercase;
        text-decoration: none;
        padding: 12px 28px;
        transition: border-color .2s, color .2s;
      }
      .btn-secondary:hover { border-color: var(--teal); color: var(--teal); }

      .divider {
        border: none;
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(217,234,223,.08), transparent);
      }

      .standby-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 10px;
        letter-spacing: .25em;
        text-transform: uppercase;
        color: var(--chartreuse);
        opacity: 0.6;
        animation: pulse-standby 3s ease-in-out infinite;
      }
      .standby-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--chartreuse);
      }

      .transmission-box {
        border-left: 2px solid rgba(255,87,45,.3);
        padding: 10px 16px;
        background: rgba(255,87,45,.04);
        font-size: 11px;
        color: rgba(217,234,223,.4);
        line-height: 1.6;
      }
    </style>
  </head>
  <body>
    <div class="scanline-sweep"></div>

    <!-- SMPTE top bar -->
    <div class="smpte-bars">
      <span style="background:#BFF13C;"></span>
      <span style="background:#06B1A2;"></span>
      <span style="background:#BFF13C;opacity:.7;"></span>
      <span style="background:#12110C;border-top:1px solid rgba(191,241,60,.2);"></span>
      <span style="background:#FF572D;"></span>
      <span style="background:#12110C;border-top:1px solid rgba(255,87,45,.15);"></span>
      <span style="background:#06B1A2;opacity:.6;"></span>
      <span style="background:#c9a227;opacity:.7;"></span>
      <span style="background:#BFF13C;opacity:.5;"></span>
      <span style="background:#FF572D;opacity:.7;"></span>
      <span style="background:#06B1A2;opacity:.4;"></span>
      <span style="background:#12110C;border-top:1px solid rgba(6,177,162,.2);"></span>
    </div>

    <!-- Nav -->
    <nav style="border-bottom:1px solid rgba(255,255,255,.04); padding:14px 32px; display:flex; align-items:center; justify-content:space-between;">
      <div style="font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:rgba(217,234,223,.2); display:flex; align-items:center; gap:8px;">
        <a href="/" style="color:inherit; text-decoration:none; transition:color .2s;" onmouseover="this.style.color='rgba(6,177,162,.7)'" onmouseout="this.style.color='rgba(217,234,223,.2)'">HackBU OS</a>
        <span>/</span>
        <span style="color:rgba(255,87,45,.5);">Live</span>
      </div>
      <div class="standby-pill">
        <span class="standby-dot"></span>
        Standby
      </div>
    </nav>

    <main style="max-width:900px; margin:0 auto; padding:40px 32px 80px;">

      <!-- Off-air badge -->
      <div class="anim-1" style="margin-bottom:32px;">
        <div class="off-air-badge">
          <span class="off-air-dot"></span>
          <span style="font-size:10px; letter-spacing:.35em; text-transform:uppercase; color:rgba(255,87,45,.7);">Signal Lost — Off Air</span>
        </div>
      </div>

      <!-- Hero title -->
      <div class="anim-2" style="margin-bottom:4px;">
        <div class="signal-title">NO<br/>SIGNAL</div>
      </div>
      <div class="anim-2" style="margin-bottom:48px;">
        <div class="signal-sub">HackBU Live — Transmission Interrupted</div>
      </div>

      <hr class="divider anim-3" style="margin-bottom:40px;" />

      <!-- Two-column layout -->
      <div class="anim-3" style="display:grid; grid-template-columns:1fr auto; gap:40px; align-items:start; margin-bottom:48px;">

        <!-- Status readout -->
        <div>
          <div style="font-size:9px; letter-spacing:.3em; text-transform:uppercase; color:rgba(6,177,162,.5); margin-bottom:12px;">Broadcast Status</div>
          <div style="font-family:'Share Tech Mono',monospace; font-size:13px; color:rgba(217,234,223,.4); line-height:2; margin-bottom:16px;">
            <div>&gt; query stream_status --live</div>
            <div style="color:rgba(255,87,45,.5);">&gt; STATUS: OFFLINE</div>
            <div>&gt; next_broadcast: <span style="color:rgba(191,241,60,.6);">{streamTime}</span></div>
            <div style="color:rgba(217,234,223,.25);">&gt; _<span class="cursor" style="color:rgba(191,241,60,.5);">█</span></div>
          </div>
          <div class="transmission-box">
            Live episodes air on Discord first — join to get notified when<br/>
            the broadcast window opens. Stream link posts 10 min before.
          </div>
        </div>

        <!-- CTA stack -->
        <div style="display:flex; flex-direction:column; gap:12px; flex-shrink:0;">
          <a href="https://discord.gg/hackbu" class="btn-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.1 18.07.11 18.083.12 18.09a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
            Join Discord
          </a>
          <a href="/" class="btn-secondary">← Back to OS</a>
        </div>
      </div>

      <!-- Upcoming shows -->
      <div class="anim-4">
        <div class="broadcast-panel" style="padding:24px 28px; margin-bottom:24px;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
            <div style="font-size:9px; letter-spacing:.35em; text-transform:uppercase; color:rgba(6,177,162,.5);">Upcoming Broadcast Schedule</div>
            <div style="font-size:9px; letter-spacing:.2em; text-transform:uppercase; color:rgba(217,234,223,.15);">Season 01</div>
          </div>

          <div class="show-row">
            <span class="show-type" style="color:rgba(6,177,162,.6); border-color:rgba(6,177,162,.25);">API Tour</span>
            <div>
              <div style="font-size:14px; color:rgba(217,234,223,.8); margin-bottom:3px;">BU Dining Services API</div>
              <div style="font-size:10px; color:rgba(217,234,223,.25); letter-spacing:.1em;">Date TBA — subscribe for alerts</div>
            </div>
          </div>

          <div class="show-row">
            <span class="show-type" style="color:rgba(255,87,45,.6); border-color:rgba(255,87,45,.25);">Ship Room</span>
            <div>
              <div style="font-size:14px; color:rgba(217,234,223,.8); margin-bottom:3px;">TerrierTransit Team</div>
              <div style="font-size:10px; color:rgba(217,234,223,.25); letter-spacing:.1em;">Date TBA — subscribe for alerts</div>
            </div>
          </div>

          <div class="show-row">
            <span class="show-type" style="color:rgba(191,241,60,.6); border-color:rgba(191,241,60,.2);">Live Bounty</span>
            <div>
              <div style="font-size:14px; color:rgba(217,234,223,.8); margin-bottom:3px;">Build a Discord Bot — live session</div>
              <div style="font-size:10px; color:rgba(217,234,223,.25); letter-spacing:.1em;">Date TBA — subscribe for alerts</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer note -->
      <div class="anim-5">
        <div style="display:flex; align-items:center; gap:16px;">
          <div style="font-size:10px; color:rgba(217,234,223,.15); letter-spacing:.15em; text-transform:uppercase; line-height:1.6;">
            Stream embeds + live episode quests coming when a broadcast is live.<br/>
            This page will auto-update when a stream is detected.
          </div>
        </div>
      </div>

    </main>

    <!-- SMPTE bottom bar -->
    <div class="smpte-bars" style="position:fixed; bottom:0; left:0; right:0; z-index:50;">
      <span style="background:#BFF13C;opacity:.15;"></span>
      <span style="background:#06B1A2;opacity:.15;"></span>
      <span style="background:#FF572D;opacity:.15;"></span>
      <span style="background:#c9a227;opacity:.15;"></span>
      <span style="background:#BFF13C;opacity:.1;"></span>
      <span style="background:#06B1A2;opacity:.12;"></span>
      <span style="background:#FF572D;opacity:.1;"></span>
      <span style="background:#BFF13C;opacity:.08;"></span>
      <span style="background:#06B1A2;opacity:.1;"></span>
      <span style="background:#c9a227;opacity:.08;"></span>
      <span style="background:#FF572D;opacity:.08;"></span>
      <span style="background:#BFF13C;opacity:.06;"></span>
    </div>

  </body>
</html>
