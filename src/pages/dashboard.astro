---
export const prerender = false;

import { getCollection } from 'astro:content';
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import mailchimp, { AUDIENCE_ID } from '../lib/mailchimp';
import { rateLimit, getClientIp } from '../lib/rate-limit';

const adminKey = import.meta.env.ADMIN_KEY;

let authorized = false;
let bountyData: Record<string, { title: string; status: string; difficulty: string; interested: any[]; lookingForTeam: any[]; teamGroups: Record<string, any[]> }> = {};
let authError = '';

// Check session cookie on any request
const sessionCookie = Astro.cookies.get('hackbu-admin')?.value;
if (sessionCookie && adminKey && sessionCookie === adminKey) {
  authorized = true;
}

// Handle login POST
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const provided = form.get('key')?.toString() || '';
  const action = form.get('action')?.toString() || '';

  if (action === 'logout') {
    Astro.cookies.delete('hackbu-admin', { path: '/' });
    authorized = false;
  } else if (adminKey && provided === adminKey) {
    // Reset doesn't matter here, successful login
    authorized = true;
    Astro.cookies.set('hackbu-admin', adminKey, {
      path: '/',
      httpOnly: true,
      secure: true,
      sameSite: 'strict',
      maxAge: 60 * 60 * 4, // 4 hours
    });
  } else {
    const ip = getClientIp(Astro.request);
    const rl = rateLimit(ip, { name: 'login', limit: 5, windowSec: 300 });
    authError = rl.allowed
      ? 'Incorrect key — try again.'
      : 'Too many failed attempts. Please wait 5 minutes.';
  }
}

// Fetch data if authorized
if (authorized) {
  let allMembers: any[] = [];
  try {
    const res = await (mailchimp as any).lists.getListMembersInfo(AUDIENCE_ID, {
      count: 1000,
      status: 'subscribed',
      fields: ['members.email_address', 'members.merge_fields', 'members.tags'],
    });
    allMembers = res.members || [];
  } catch (e) { console.error('Failed to fetch members:', e); }

  function getMembersWithTag(tag: string) {
    return allMembers
      .filter((m: any) => (m.tags || []).some((t: any) => t.name === tag))
      .map((m: any) => ({
        name: `${m.merge_fields?.FNAME || ''} ${m.merge_fields?.LNAME || ''}`.trim() || '(unknown)',
        email: m.email_address,
        workingMode: 'unknown',
        teammates: m.merge_fields?.TEAMMATES || '',
        teamGroupIds: (m.tags || [])
          .filter((t: any) => t.name.startsWith('team-group:'))
          .map((t: any) => t.name),
      }));
  }

  function getEmailsWithTag(tag: string): Set<string> {
    return new Set(
      allMembers
        .filter((m: any) => (m.tags || []).some((t: any) => t.name === tag))
        .map((m: any) => m.email_address)
    );
  }

  const entries = await getCollection('bounties');
  for (const entry of entries) {
    const s = entry.slug;
    const interested = getMembersWithTag(`interested:${s}`);
    const lookingForTeam = getMembersWithTag(`team:${s}`);
    const soloSet = getEmailsWithTag(`solo:${s}`);
    const hasTeamSet = getEmailsWithTag(`has-team:${s}`);
    for (const r of interested) {
      if (soloSet.has(r.email)) r.workingMode = 'solo';
      else if (hasTeamSet.has(r.email)) r.workingMode = 'has-team';
    }
    // Build team groups from team-group tags
    const teamGroups: Record<string, any[]> = {};
    for (const r of interested) {
      const teamTag = (r.teamGroupIds || []).find((t: string) => t.startsWith(`team-group:${s}:`));
      if (teamTag) {
        const tId = teamTag.split(':')[2];
        if (!teamGroups[tId]) teamGroups[tId] = [];
        teamGroups[tId].push(r);
      }
    }
    bountyData[s] = { title: entry.data.title, status: entry.data.status, difficulty: entry.data.difficulty, interested, lookingForTeam, teamGroups };
  }
}

const totalInterested = Object.values(bountyData).reduce((n, d) => n + d.interested.length, 0);
const totalTeam = Object.values(bountyData).reduce((n, d) => n + d.lookingForTeam.length, 0);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Bounty Responses</title>
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('hackbu-theme');
        var theme = stored || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <script defer src="https://cloud.umami.is/script.js" data-website-id="6268acbc-ec7d-467c-82e3-a2719f9e0967"></script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --bg: #0a0a0a;
        --surface: #111;
        --border: #1e2e2e;
        --border-light: #253535;
        --text: #d8d8c8;
        --muted: #5a6a6a;
        --teal: #3dd6c0;
        --chartreuse: #c8f135;
        --orange: #f59e0b;
        --red: #f87171;
      }
      html { font-size: 14px; }
      body { font-family: 'SF Mono', 'Fira Code', monospace; background: var(--bg); color: var(--text); min-height: 100vh; }

      /* ── Login gate ── */
      .gate-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 2rem; }
      .gate { width: 100%; max-width: 340px; }
      .gate-logo { color: var(--chartreuse); font-size: 1.4rem; font-weight: 700; margin-bottom: 0.25rem; letter-spacing: -0.5px; }
      .gate-sub { color: var(--muted); font-size: 0.8rem; margin-bottom: 2rem; }
      .gate label { display: block; color: var(--teal); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem; }
      .gate input {
        width: 100%; padding: 0.65rem 0.85rem;
        background: var(--surface); border: 1px solid var(--border);
        color: var(--text); font-family: inherit; font-size: 0.9rem;
        border-radius: 8px; outline: none; transition: border-color 0.15s;
        margin-bottom: 0.6rem;
      }
      .gate input:focus { border-color: var(--chartreuse); }
      .gate-error { color: var(--red); font-size: 0.78rem; margin-bottom: 0.6rem; }
      .gate button {
        width: 100%; padding: 0.65rem;
        background: var(--chartreuse); color: #0a0a0a;
        font-family: inherit; font-weight: 700; font-size: 0.88rem;
        border: none; border-radius: 8px; cursor: pointer; transition: opacity 0.15s;
      }
      .gate button:hover { opacity: 0.88; }

      /* ── Shell ── */
      .shell { display: grid; grid-template-columns: 220px 1fr; min-height: 100vh; }

      /* ── Sidebar ── */
      .sidebar { background: var(--surface); border-right: 1px solid var(--border); padding: 1.5rem 1.25rem; position: sticky; top: 0; height: 100vh; overflow-y: auto; }
      .sidebar-logo { color: var(--chartreuse); font-size: 1rem; font-weight: 700; margin-bottom: 0.2rem; }
      .sidebar-sub { color: var(--muted); font-size: 0.72rem; margin-bottom: 1.5rem; }
      .sidebar-stat { display: flex; justify-content: space-between; align-items: center; padding: 0.45rem 0; border-bottom: 1px solid var(--border); font-size: 0.78rem; color: var(--muted); }
      .sidebar-stat span:last-child { color: var(--text); font-weight: 600; }
      .sidebar-nav { margin-top: 1.5rem; }
      .sidebar-nav-title { color: var(--muted); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.6rem; }
      .sidebar-link { display: block; padding: 0.4rem 0.6rem; border-radius: 6px; color: var(--text); font-size: 0.78rem; text-decoration: none; margin-bottom: 0.2rem; transition: background 0.12s; }
      .sidebar-link:hover { background: #1a2a2a; }
      .sidebar-link .dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; margin-right: 0.5rem; background: var(--teal); }

      /* ── Main ── */
      .main { padding: 2rem 2.5rem; overflow-y: auto; }
      .page-title { color: var(--chartreuse); font-size: 1.2rem; font-weight: 700; margin-bottom: 0.25rem; }
      .page-sub { color: var(--muted); font-size: 0.78rem; margin-bottom: 2rem; }

      /* ── Stats row ── */
      .stats { display: flex; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap; }
      .stat-card { flex: 1; min-width: 140px; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 1rem 1.25rem; }
      .stat-label { color: var(--muted); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.35rem; }
      .stat-value { font-size: 1.6rem; font-weight: 700; line-height: 1; }
      .stat-value.green { color: var(--chartreuse); }
      .stat-value.orange { color: var(--orange); }

      /* ── Bounty section ── */
      .bounty-section { margin-bottom: 2.5rem; scroll-margin-top: 2rem; }
      .bounty-header { display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 1.25rem; }
      .bounty-title { color: var(--chartreuse); font-size: 1rem; font-weight: 700; }
      .bounty-slug { color: var(--muted); font-size: 0.72rem; }

      /* ── Sub-section tabs ── */
      .sub-section { margin-bottom: 1.25rem; }
      .sub-label {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--muted); margin-bottom: 0.75rem;
      }
      .sub-label .pill {
        padding: 0.15rem 0.5rem; border-radius: 99px; font-size: 0.68rem; font-weight: 700;
      }
      .pill-green { background: rgba(200,241,53,0.12); color: var(--chartreuse); border: 1px solid rgba(200,241,53,0.25); }
      .pill-orange { background: rgba(245,158,11,0.12); color: var(--orange); border: 1px solid rgba(245,158,11,0.25); }

      /* ── Person cards ── */
      .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.75rem; }
      .card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 0.9rem 1rem; position: relative; }
      .card:hover { border-color: var(--border-light); }
      .card-name { font-weight: 600; font-size: 0.88rem; color: var(--text); margin-bottom: 0.2rem; }
      .card-email { color: var(--muted); font-size: 0.76rem; margin-bottom: 0.5rem; word-break: break-all; }
      .card-footer { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
      .badge {
        display: inline-flex; align-items: center; gap: 0.3rem;
        padding: 0.15rem 0.55rem; border-radius: 99px; font-size: 0.68rem; font-weight: 600;
      }
      .badge-solo { background: rgba(61,214,192,0.1); color: var(--teal); border: 1px solid rgba(61,214,192,0.2); }
      .badge-hasteam { background: rgba(245,158,11,0.1); color: var(--orange); border: 1px solid rgba(245,158,11,0.2); }
      .badge-unknown { background: #181818; color: var(--muted); border: 1px solid var(--border); }
      .card-teammates { margin-top: 0.6rem; padding-top: 0.6rem; border-top: 1px solid var(--border); font-size: 0.74rem; color: var(--muted); line-height: 1.5; }
      .card-teammates strong { color: var(--text); }

      .team-group { border: 1px solid var(--orange); border-radius: 10px; padding: 0.75rem; margin-bottom: 0.75rem; }
      .team-group-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--orange); margin-bottom: 0.5rem; font-weight: 600; }
      .team-group .cards { margin-bottom: 0; }
      [data-theme="light"] .team-group { border-color: rgba(180,83,9,0.3); }
      [data-theme="light"] .team-group-label { color: #b45309; }
      .empty-state { color: var(--muted); font-size: 0.8rem; padding: 0.75rem 1rem; background: var(--surface); border: 1px dashed var(--border); border-radius: 8px; }

      .divider { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }


      /* ── Light mode ── */
      [data-theme="light"] body { background: #f5f5f0; color: #1a1a1a; }
      [data-theme="light"] .gate-wrap { background: #f5f5f0; }
      [data-theme="light"] .gate-logo { color: #0d6b5e; }
      [data-theme="light"] .gate-sub { color: #666; }
      [data-theme="light"] .gate label { color: #0d6b5e; }
      [data-theme="light"] .gate input { background: #fff; border-color: #d0d0d0; color: #1a1a1a; }
      [data-theme="light"] .gate input:focus { border-color: #0d6b5e; }
      [data-theme="light"] .gate button { background: #0d6b5e; color: #fff; }
      [data-theme="light"] .sidebar { background: #eaeae5; border-color: #d0d0d0; }
      [data-theme="light"] .sidebar-logo { color: #0d6b5e; }
      [data-theme="light"] .sidebar-sub { color: #666; }
      [data-theme="light"] .sidebar-stat { border-color: #d0d0d0; color: #666; }
      [data-theme="light"] .sidebar-stat span:last-child { color: #1a1a1a; }
      [data-theme="light"] .sidebar-nav-title { color: #888; }
      [data-theme="light"] .sidebar-link { color: #1a1a1a; }
      [data-theme="light"] .sidebar-link:hover { background: #ddddd8; }
      [data-theme="light"] .sidebar-link .dot { background: #0d6b5e; }
      [data-theme="light"] .page-title { color: #0d6b5e; }
      [data-theme="light"] .page-sub { color: #666; }
      [data-theme="light"] .stat-card { background: #fff; border-color: #d0d0d0; }
      [data-theme="light"] .stat-label { color: #666; }
      [data-theme="light"] .stat-value.green { color: #0d6b5e; }
      [data-theme="light"] .stat-value.orange { color: #b45309; }
      [data-theme="light"] .bounty-title { color: #0d6b5e; }
      [data-theme="light"] .bounty-slug { color: #888; }
      [data-theme="light"] .sub-label { color: #666; }
      [data-theme="light"] .pill-green { background: rgba(13,107,94,0.1); color: #0d6b5e; border-color: rgba(13,107,94,0.3); }
      [data-theme="light"] .pill-orange { background: rgba(180,83,9,0.1); color: #b45309; border-color: rgba(180,83,9,0.3); }
      [data-theme="light"] .card { background: #fff; border-color: #d0d0d0; }
      [data-theme="light"] .card:hover { border-color: #bbb; }
      [data-theme="light"] .card-name { color: #1a1a1a; }
      [data-theme="light"] .card-email { color: #666; }
      [data-theme="light"] .badge-solo { background: rgba(13,107,94,0.1); color: #0d6b5e; border-color: rgba(13,107,94,0.25); }
      [data-theme="light"] .badge-hasteam { background: rgba(180,83,9,0.1); color: #b45309; border-color: rgba(180,83,9,0.25); }
      [data-theme="light"] .badge-unknown { background: #f0f0f0; color: #888; border-color: #d0d0d0; }
      [data-theme="light"] .card-teammates { border-color: #e0e0e0; color: #666; }
      [data-theme="light"] .card-teammates strong { color: #1a1a1a; }
      [data-theme="light"] .empty-state { background: #fff; border-color: #d0d0d0; color: #888; }
      [data-theme="light"] .divider { border-color: #d0d0d0; }
      .merge-card { position: relative; }
      .merge-action-bar { display: none; }
      .merge-action-bar.visible { display: flex !important; }
      [data-theme="light"] #dash-search,
      [data-theme="light"] #dash-bounty-filter { background: #fff !important; border-color: #d0d0d0 !important; color: #1a1a1a !important; }
      [data-theme="light"] #dash-search:focus,
      [data-theme="light"] #dash-bounty-filter:focus { border-color: #0d6b5e !important; }
      [data-theme="light"] #export-csv { background: #0d6b5e !important; color: #fff !important; }
      [data-theme="light"] .winner-select,
      [data-theme="light"] .winner-url { background: #fff !important; border-color: #d0d0d0 !important; color: #1a1a1a !important; }
      [data-theme="light"] .declare-btn { background: #b45309 !important; color: #fff !important; }

      @media (max-width: 640px) {
        .shell { grid-template-columns: 1fr; }
        .sidebar { position: static; height: auto; }
        .main { padding: 1.25rem; }
      }
    </style>
  </head>
  <body>
    <ThemeToggle />

    {!authorized ? (
      <div class="gate-wrap">
        <div class="gate">
          <div class="gate-logo">HackBU Admin</div>
          <div class="gate-sub">Bounty response dashboard</div>
          <form method="POST">
            <label for="key">Admin key</label>
            {authError && <p class="gate-error">{authError}</p>}
            <input type="password" id="key" name="key" placeholder="Enter admin key" autofocus autocomplete="current-password" />
            <button type="submit">Unlock dashboard →</button>
          </form>
        </div>
      </div>
    ) : (
      <div class="shell">
        <!-- Sidebar -->
        <aside class="sidebar">
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <div class="sidebar-logo">HackBU Admin</div>
            <form method="POST" style="margin:0;">
              <input type="hidden" name="action" value="logout" />
              <button type="submit" style="background:none;border:1px solid var(--border);color:var(--muted);font-family:inherit;font-size:0.68rem;padding:0.25rem 0.5rem;border-radius:4px;cursor:pointer;">Logout</button>
            </form>
          </div>
          <div class="sidebar-sub">Bounty responses</div>

          <div class="sidebar-stat">
            <span>Total interested</span>
            <span>{totalInterested}</span>
          </div>
          <div class="sidebar-stat">
            <span>Looking for team</span>
            <span>{totalTeam}</span>
          </div>
          <div class="sidebar-stat">
            <span>Active bounties</span>
            <span>{Object.keys(bountyData).length}</span>
          </div>

          <nav class="sidebar-nav">
            <div class="sidebar-nav-title">Bounties</div>
            {Object.entries(bountyData).map(([s, d]) => (
              <a href={`#${s}`} class="sidebar-link">
                <span class="dot" />
                {d.title}
              </a>
            ))}
          </nav>
        </aside>

        <!-- Main content -->
        <main class="main">
          <div class="page-title">Responses</div>
          <div class="page-sub">Live data from Mailchimp — refreshes on each page load.</div>

          <!-- Summary stats -->
          <div class="stats">
            <div class="stat-card">
              <div class="stat-label">Total interested</div>
              <div class="stat-value green">{totalInterested}</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">Looking for teammates</div>
              <div class="stat-value orange">{totalTeam}</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">Active bounties</div>
              <div class="stat-value" style="color: var(--teal)">{Object.keys(bountyData).length}</div>
            </div>
          </div>

          <!-- Search & Filter -->
          <div style="display:flex;gap:0.75rem;margin-bottom:1.5rem;flex-wrap:wrap;">
            <input type="text" id="dash-search" placeholder="Search by name or email..." style="flex:1;min-width:200px;padding:0.55rem 0.85rem;background:var(--surface);border:1px solid var(--border);color:var(--text);font-family:inherit;font-size:0.82rem;border-radius:8px;outline:none;" />
            <select id="dash-bounty-filter" style="padding:0.55rem 0.85rem;background:var(--surface);border:1px solid var(--border);color:var(--text);font-family:inherit;font-size:0.82rem;border-radius:8px;outline:none;">
              <option value="">All bounties</option>
              {Object.entries(bountyData).map(([s, d]) => (
                <option value={s}>{d.title}</option>
              ))}
            </select>
            <button id="export-csv" style="padding:0.55rem 1rem;background:var(--chartreuse);color:#0a0a0a;font-family:inherit;font-weight:700;font-size:0.82rem;border:none;border-radius:8px;cursor:pointer;white-space:nowrap;" title="Export all responses as CSV">Export CSV ↓</button>
          </div>

          {Object.entries(bountyData).map(([s, data], i) => (
            <section class="bounty-section" id={s}>
              {i > 0 && <hr class="divider" />}
              <div class="bounty-header">
                <span class="bounty-title">{data.title}</span>
                <span class="bounty-slug">{s}</span>
              </div>

              <!-- Interested -->
              <div class="sub-section">
                <div class="sub-label">
                  Interested
                  <span class={`pill pill-green`}>{data.interested.length}</span>
                </div>
                {data.interested.length === 0 ? (
                  <div class="empty-state">No responses yet.</div>
                ) : (
                  <div>
                    {/* Team groups */}
                    {Object.entries(data.teamGroups).map(([tId, members]) => (
                      <div class="team-group">
                        <div class="team-group-label">Team {tId}</div>
                        <div class="cards">
                          {members.map((r: any) => (
                            <div class="card">
                              <div class="card-name">{r.name}</div>
                              <div class="card-email">{r.email}</div>
                              <div class="card-footer">
                                <span class="badge badge-hasteam">Team</span>
                              </div>
                            </div>
                          ))}
                        </div>
                      </div>
                    ))}
                    {/* Solo / ungrouped members */}
                    {(() => {
                      const groupedEmails = new Set(Object.values(data.teamGroups).flat().map((r: any) => r.email));
                      const ungrouped = data.interested.filter((r: any) => !groupedEmails.has(r.email));
                      return ungrouped.length > 0 && (
                        <div class="cards">
                          {ungrouped.map((r: any) => (
                            <div class="card merge-card" data-email={r.email}>
                              <input type="checkbox" class="merge-checkbox" style="position:absolute;top:0.6rem;right:0.6rem;accent-color:var(--teal);cursor:pointer;" />
                              <div class="card-name">{r.name}</div>
                              <div class="card-email">{r.email}</div>
                              <div class="card-footer">
                                {r.workingMode === 'solo' && <span class="badge badge-solo">Solo</span>}
                                {r.workingMode === 'has-team' && <span class="badge badge-hasteam">Has team</span>}
                                {r.workingMode === 'unknown' && <span class="badge badge-unknown">—</span>}
                              </div>
                              {r.teammates && (
                                <div class="card-teammates">
                                  <strong>Teammates:</strong> {r.teammates}
                                </div>
                              )}
                            </div>
                          ))}
                        </div>
                      );
                    })()}
                    <div class="merge-action-bar" style="margin-top:0.75rem;background:#1a2a2a;border:1px solid var(--orange);border-radius:8px;padding:0.6rem 0.85rem;align-items:center;gap:0.75rem;flex-wrap:wrap;">
                      <span class="merge-count" style="color:var(--orange);font-size:0.78rem;font-weight:600;">0 selected</span>
                      <button class="merge-new-btn" style="padding:0.35rem 0.75rem;background:var(--orange);color:#0a0a0a;border:none;border-radius:6px;font-size:0.75rem;font-weight:700;cursor:pointer;" disabled>Merge into new team</button>
                      <select class="merge-existing-select" style="padding:0.35rem 0.75rem;background:transparent;color:var(--orange);border:1px solid rgba(245,158,11,0.4);border-radius:6px;font-size:0.75rem;font-family:inherit;cursor:pointer;">
                        <option value="">Add to existing team ▾</option>
                        {Object.keys(data.teamGroups).map((tId) => (
                          <option value={tId}>Team {tId}</option>
                        ))}
                      </select>
                      <button class="merge-clear-btn" style="padding:0.35rem 0.75rem;background:transparent;color:var(--muted);border:1px solid var(--border);border-radius:6px;font-size:0.75rem;cursor:pointer;">Clear</button>
                    </div>
                  </div>
                )}
              </div>

              <!-- Looking for teammates -->
              <div class="sub-section">
                <div class="sub-label">
                  Looking for teammates
                  <span class="pill pill-orange">{data.lookingForTeam.length}</span>
                </div>
                {data.lookingForTeam.length === 0 ? (
                  <div class="empty-state">No responses yet.</div>
                ) : (
                  <div class="cards">
                    {data.lookingForTeam.map((r: any) => (
                      <div class="card">
                        <div class="card-name">{r.name}</div>
                        <div class="card-email">{r.email}</div>
                      </div>
                    ))}
                  </div>
                )}
              </div>

              <!-- Declare Winner -->
              <div class="sub-section" style="margin-top:1.5rem;">
                {data.status === 'completed' ? (
                  <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.5rem 1rem;border-radius:8px;background:rgba(168,85,247,0.1);border:1px solid rgba(168,85,247,0.3);color:#c084fc;font-size:0.82rem;font-weight:600;">
                    <span>🏆</span>
                    <span>Winner declared</span>
                  </div>
                ) : data.status === 'closed' ? (
                  <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.5rem 1rem;border-radius:8px;background:rgba(100,100,100,0.1);border:1px solid rgba(100,100,100,0.3);color:var(--muted);font-size:0.82rem;">
                    Bounty closed
                  </div>
                ) : (
                  <div class="winner-form" data-slug={s} data-title={data.title}>
                    <div class="sub-label" style="margin-bottom:0.75rem;">
                      Declare Winner
                    </div>
                    <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:flex-end;">
                      <div style="flex:1;min-width:180px;">
                        <label style="display:block;font-size:0.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.3rem;">Winner</label>
                        <select class="winner-select" style="width:100%;padding:0.55rem 0.85rem;background:var(--surface);border:1px solid var(--border);color:var(--text);font-family:inherit;font-size:0.82rem;border-radius:8px;outline:none;">
                          <option value="">Select winner...</option>
                          {Object.entries(data.teamGroups).map(([tId, members]) => (
                            <option value={`Team ${tId}`}>Team {tId} ({members.map((m: any) => m.name).join(', ')})</option>
                          ))}
                          {data.interested.map((r: any) => (
                            <option value={r.name}>{r.name} ({r.email})</option>
                          ))}
                        </select>
                      </div>
                      <div style="flex:1;min-width:180px;">
                        <label style="display:block;font-size:0.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.3rem;">Submission URL (optional)</label>
                        <input type="url" class="winner-url" placeholder="https://github.com/..." style="width:100%;padding:0.55rem 0.85rem;background:var(--surface);border:1px solid var(--border);color:var(--text);font-family:inherit;font-size:0.82rem;border-radius:8px;outline:none;" />
                      </div>
                      <button type="button" class="declare-btn" style="padding:0.55rem 1.25rem;background:var(--orange);color:#0a0a0a;font-family:inherit;font-weight:700;font-size:0.82rem;border:none;border-radius:8px;cursor:pointer;white-space:nowrap;">
                        Declare Winner 🏆
                      </button>
                    </div>
                  </div>
                )}
              </div>
            </section>
          ))}
        </main>
      </div>
    )}

    <script is:inline>
      const searchInput = document.getElementById('dash-search');
      const bountyFilter = document.getElementById('dash-bounty-filter');

      function applyFilters() {
        const query = (searchInput?.value || '').toLowerCase().trim();
        const bountySlug = bountyFilter?.value || '';

        document.querySelectorAll('.bounty-section').forEach(section => {
          const sectionId = section.id;
          if (bountySlug && sectionId !== bountySlug) {
            section.style.display = 'none';
            return;
          }
          section.style.display = '';

          section.querySelectorAll('.card').forEach(card => {
            const name = (card.querySelector('.card-name')?.textContent || '').toLowerCase();
            const email = (card.querySelector('.card-email')?.textContent || '').toLowerCase();
            const teammates = (card.querySelector('.card-teammates')?.textContent || '').toLowerCase();
            const match = !query || name.includes(query) || email.includes(query) || teammates.includes(query);
            card.style.display = match ? '' : 'none';
          });
        });
      }

      searchInput?.addEventListener('input', applyFilters);
      bountyFilter?.addEventListener('change', applyFilters);

      // CSV Export
      function sanitizeCsvCell(value) {
        const cell = String(value ?? '');
        return /^[=+\-@]/.test(cell) ? "'" + cell : cell;
      }
      document.getElementById('export-csv')?.addEventListener('click', function() {
        const rows = [['Bounty', 'Name', 'Email', 'Working Mode', 'Teammates', 'Tags']];
        document.querySelectorAll('.bounty-section').forEach(section => {
          const title = section.querySelector('.bounty-title')?.textContent || '';
          section.querySelectorAll('.sub-section').forEach(sub => {
            const tag = (sub.querySelector('.sub-label')?.textContent || '').trim().split('\n')[0].trim();
            sub.querySelectorAll('.card').forEach(card => {
              const name = card.querySelector('.card-name')?.textContent || '';
              const email = card.querySelector('.card-email')?.textContent || '';
              const badge = card.querySelector('.badge')?.textContent?.trim() || '';
              const teammates = (card.querySelector('.card-teammates')?.textContent || '').replace('Teammates:', '').trim();
              rows.push([title, name, email, badge, teammates, tag].map(sanitizeCsvCell));
            });
          });
        });
        const csv = rows.map(r => r.map(c => '"' + c.replace(/"/g, '""') + '"').join(',')).join('\n');
        const blob = new Blob([csv], { type: 'text/csv' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'hackbu-responses-' + new Date().toISOString().slice(0,10) + '.csv';
        a.click();
        URL.revokeObjectURL(a.href);
      });
      // Declare Winner
      document.querySelectorAll('.declare-btn').forEach(btn => {
        btn.addEventListener('click', async function() {
          const form = btn.closest('.winner-form');
          if (!form) return;
          const slug = form.dataset.slug;
          const title = form.dataset.title;
          const select = form.querySelector('.winner-select');
          const urlInput = form.querySelector('.winner-url');
          const winner = select?.value;
          const winnerSubmission = urlInput?.value || '';

          if (!winner) {
            alert('Please select a winner.');
            return;
          }

          if (!confirm(`Declare "${winner}" as the winner of "${title}"?\n\nThis will mark the bounty as completed.`)) {
            return;
          }

          btn.disabled = true;
          btn.textContent = 'Submitting...';

          try {
            const res = await fetch('/api/declare-winner', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ slug, winner, winnerSubmission: winnerSubmission || undefined }),
            });
            const data = await res.json();
            if (res.ok) {
              alert('Winner declared! Reloading...');
              location.reload();
            } else {
              alert('Error: ' + (data.error || 'Unknown error'));
              btn.disabled = false;
              btn.textContent = 'Declare Winner 🏆';
            }
          } catch (err) {
            alert('Network error: ' + err.message);
            btn.disabled = false;
            btn.textContent = 'Declare Winner 🏆';
          }
        });
      });

      // Merge team logic
      function updateMergeBar(slug) {
        const section = document.getElementById(slug);
        if (!section) return;
        const checked = section.querySelectorAll('.merge-checkbox:checked');
        const bar = section.querySelector('.merge-action-bar');
        const countEl = section.querySelector('.merge-count');
        const newBtn = section.querySelector('.merge-new-btn');
        const existingSelect = section.querySelector('.merge-existing-select');

        if (!bar || !countEl || !newBtn || !existingSelect) return;

        const n = checked.length;
        countEl.textContent = n + ' selected';

        if (n > 0) {
          bar.classList.add('visible');
        } else {
          bar.classList.remove('visible');
        }

        newBtn.disabled = n < 2;
        const hasTeams = existingSelect.options.length > 1;
        existingSelect.disabled = !hasTeams || n < 1;
      }

      // Checkbox change handler (delegated per bounty section)
      document.querySelectorAll('.bounty-section').forEach(function(bountySection) {
        bountySection.addEventListener('change', function(e) {
          if (e.target && e.target.classList.contains('merge-checkbox')) {
            const card = e.target.closest('.merge-card');
            if (card) {
              card.style.borderColor = e.target.checked ? 'var(--teal)' : '';
              card.style.borderWidth = e.target.checked ? '1.5px' : '';
            }
            updateMergeBar(bountySection.id);
          }
        });
      });

      async function doMerge(slug, emails, existingTeamId) {
        const payload = { slug: slug, emails: emails };
        if (existingTeamId) payload.existingTeamId = existingTeamId;

        const res = await fetch('/api/admin/merge-team', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();
        if (res.ok) {
          alert('Team updated! Reloading...');
          location.reload();
        } else {
          alert('Error: ' + (data.error || 'Unknown error'));
        }
      }

      // "Merge into new team" button
      document.querySelectorAll('.merge-new-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          const bountySection = btn.closest('.bounty-section');
          if (!bountySection) return;
          const slug = bountySection.id;
          const emails = Array.from(bountySection.querySelectorAll('.merge-checkbox:checked'))
            .map(function(cb) { return cb.closest('.merge-card') && cb.closest('.merge-card').dataset.email; })
            .filter(Boolean);

          if (emails.length < 2) { alert('Select at least 2 people to form a team.'); return; }
          if (!confirm('Merge ' + emails.length + ' people into a new team for "' + slug + '"?')) return;

          btn.disabled = true;
          btn.textContent = 'Merging...';
          try {
            await doMerge(slug, emails, null);
          } catch (err) {
            alert('Network error: ' + err.message);
            btn.disabled = false;
            btn.textContent = 'Merge into new team';
          }
        });
      });

      // "Add to existing team" select
      document.querySelectorAll('.merge-existing-select').forEach(function(sel) {
        sel.addEventListener('change', async function() {
          const teamId = sel.value;
          if (!teamId) return;
          const bountySection = sel.closest('.bounty-section');
          if (!bountySection) return;
          const slug = bountySection.id;
          const emails = Array.from(bountySection.querySelectorAll('.merge-checkbox:checked'))
            .map(function(cb) { return cb.closest('.merge-card') && cb.closest('.merge-card').dataset.email; })
            .filter(Boolean);

          if (emails.length < 1) { sel.value = ''; return; }
          if (!confirm('Add ' + emails.length + ' person(s) to Team ' + teamId + '?')) { sel.value = ''; return; }

          sel.disabled = true;
          try {
            await doMerge(slug, emails, teamId);
          } catch (err) {
            alert('Network error: ' + err.message);
            sel.disabled = false;
            sel.value = '';
          }
        });
      });

      // "Clear" button
      document.querySelectorAll('.merge-clear-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          const bountySection = btn.closest('.bounty-section');
          if (!bountySection) return;
          bountySection.querySelectorAll('.merge-checkbox:checked').forEach(function(cb) {
            cb.checked = false;
            const card = cb.closest('.merge-card');
            if (card) { card.style.borderColor = ''; card.style.borderWidth = ''; }
          });
          updateMergeBar(bountySection.id);
        });
      });
    </script>
  </body>
</html>
