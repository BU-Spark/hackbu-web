---
export const prerender = false;

import '../../styles/global.css';
import { getCollection } from 'astro:content';

const { slug } = Astro.params;
const teamId = Astro.url.searchParams.get('team') || '';

const entries = await getCollection('bounties');
const entry = entries.find((e) => e.slug === slug);
const bounty = entry?.data;
const isOpen = bounty?.status === 'open';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{bounty ? `Join Team — ${bounty.title}` : 'Invalid Link'} — HackBU</title>
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('hackbu-theme');
        var theme = stored || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <script defer src="https://cloud.umami.is/script.js" data-website-id="6268acbc-ec7d-467c-82e3-a2719f9e0967"></script>
    <style>
      body::before {
        content:"";position:fixed;inset:0;
        background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.06) 2px,rgba(0,0,0,0.06) 4px);
        pointer-events:none;z-index:100;
      }
      body {
        background-image:radial-gradient(rgba(6,177,162,0.07) 1px,transparent 1px);
        background-size:28px 28px;
      }
      .field-input:focus{outline:none;border-color:rgba(191,241,60,.6);box-shadow:0 0 0 2px rgba(191,241,60,.08);}
    </style>
  </head>
  <body class="min-h-screen bg-spark-black text-spark-eggshell theme-body flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      {!bounty || !isOpen || !teamId ? (
        <div class="border border-red-500/30 p-6 text-center space-y-3">
          <h1 class="font-display text-2xl text-red-400">Invalid Link</h1>
          <p class="text-spark-eggshell/60 text-sm font-mono">
            {!bounty ? 'This bounty does not exist.' : !isOpen ? 'This bounty is no longer accepting registrations.' : 'Missing team ID.'}
          </p>
          <a href="/" class="inline-block mt-2 text-spark-teal text-sm font-mono hover:underline">Go to HackBU OS</a>
        </div>
      ) : (
        <div class="border border-spark-teal/30 p-6 space-y-4" style="border-top-color:rgba(191,241,60,.3);">
          <div>
            <p class="text-spark-teal/60 text-[10px] font-mono uppercase tracking-[.2em] mb-1">Join Team</p>
            <h1 class="font-display text-2xl text-spark-chartreuse">{bounty.title}</h1>
            <p class="text-spark-eggshell/50 text-sm font-mono mt-1">You've been invited to join a team for this bounty.</p>
          </div>

          <div id="form-area" class="space-y-3">
            <input id="input-fname" type="text" placeholder="First Name" class="field-input w-full px-4 py-3 bg-spark-black border border-spark-teal/30 text-spark-eggshell font-mono text-sm transition-all" />
            <input id="input-lname" type="text" placeholder="Last Name" class="field-input w-full px-4 py-3 bg-spark-black border border-spark-teal/30 text-spark-eggshell font-mono text-sm transition-all" />
            <input id="input-email" type="email" placeholder="you@bu.edu" class="field-input w-full px-4 py-3 bg-spark-black border border-spark-teal/30 text-spark-eggshell font-mono text-sm transition-all" />
            <p id="form-error" class="text-red-400 text-xs font-mono hidden"></p>
            <button id="submit-btn" class="w-full px-4 py-3 bg-spark-chartreuse text-spark-black font-mono font-bold text-sm cursor-pointer transition-colors hover:bg-spark-chartreuse/85">
              Join Team
            </button>
          </div>

          <div id="success-area" class="hidden space-y-3 text-center">
            <div class="text-spark-chartreuse font-display text-xl">You're in!</div>
            <p class="text-spark-eggshell/60 text-sm font-mono">You've been registered for this bounty. Check your email for next steps.</p>
            <a href={`/bounties/${slug}`} class="inline-block text-spark-teal text-sm font-mono hover:underline">View Bounty Details</a>
          </div>
        </div>
      )}
    </div>

    {bounty && isOpen && teamId && (
      <script define:vars={{ slug, teamId }}>
        const fname = document.getElementById('input-fname');
        const lname = document.getElementById('input-lname');
        const email = document.getElementById('input-email');
        const error = document.getElementById('form-error');
        const btn = document.getElementById('submit-btn');
        const formArea = document.getElementById('form-area');
        const successArea = document.getElementById('success-area');

        // Restore stored data
        try {
          const stored = JSON.parse(localStorage.getItem('hackbu-user-data') || '{}');
          if (stored.fname) fname.value = stored.fname;
          if (stored.lname) lname.value = stored.lname;
          if (stored.email) email.value = stored.email;
        } catch {}

        btn.addEventListener('click', async () => {
          const f = fname.value.trim(), l = lname.value.trim(), e = email.value.trim();
          if (!f || !l) { error.textContent = 'Please enter your first and last name.'; error.classList.remove('hidden'); return; }
          if (!e || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e)) { error.textContent = 'Please enter a valid email.'; error.classList.remove('hidden'); return; }

          btn.disabled = true;
          btn.textContent = 'Joining...';
          try {
            const res = await fetch('/api/team-join', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ first_name: f, last_name: l, email: e, bounty_slug: slug, team_id: teamId }),
            });
            if (res.status === 404) { error.textContent = 'This team link is invalid or expired.'; error.classList.remove('hidden'); btn.disabled = false; btn.textContent = 'Join Team'; return; }
            if (!res.ok) { error.textContent = 'Something went wrong. Please try again.'; error.classList.remove('hidden'); btn.disabled = false; btn.textContent = 'Join Team'; return; }

            localStorage.setItem('hackbu-user-data', JSON.stringify({ fname: f, lname: l, email: e }));
            // Save response locally
            try {
              const responses = JSON.parse(localStorage.getItem('hackbu-bounty-responses') || '{}');
              if (!responses[slug]) responses[slug] = {};
              responses[slug]['interested'] = { fname: f, lname: l, email: e, teamId, timestamp: new Date().toISOString() };
              localStorage.setItem('hackbu-bounty-responses', JSON.stringify(responses));
            } catch {}

            formArea.classList.add('hidden');
            successArea.classList.remove('hidden');
          } catch {
            error.textContent = 'No connection. Please try again.';
            error.classList.remove('hidden');
            btn.disabled = false;
            btn.textContent = 'Join Team';
          }
        });
      </script>
    )}
  </body>
</html>
