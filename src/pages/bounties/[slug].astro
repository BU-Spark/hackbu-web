---
import '../../styles/global.css';
import bounties from '../../data/bounties.json';
export function getStaticPaths() {
  return bounties.map((b: any) => ({
    params: { slug: b.slug },
  }));
}

const { slug } = Astro.params;
const bounty = bounties.find((b: any) => b.slug === slug)!;
const tags: string[] = typeof bounty.tags === 'string' ? JSON.parse(bounty.tags) : bounty.tags;

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{bounty.title} - HackBU Bounties</title>
  </head>
  <body class="min-h-screen flex items-center justify-center p-4 bg-spark-black">
    <div class="max-w-3xl w-full bg-spark-black/80 border border-spark-teal/30 rounded-xl p-6 lg:p-8 shadow-2xl">
      <div class="mb-4">
        <span class="inline-block px-3 py-1 bg-spark-teal/20 border border-spark-teal/40 rounded text-xs font-mono uppercase tracking-wider text-spark-teal mb-3">
          {bounty.status}
        </span>
        <h1 class="font-display text-3xl lg:text-4xl text-spark-chartreuse mb-3">
          {bounty.title}
        </h1>

        <div class="flex flex-wrap gap-2 mb-4">
          <div class="px-3 py-1 bg-spark-orange text-spark-black rounded-lg font-semibold text-sm">
            ${bounty.prize}
          </div>
          <div class="px-3 py-1 border border-spark-teal/50 rounded-lg text-spark-eggshell/80 font-mono text-sm">
            Deadline: {bounty.deadline}
          </div>
          {bounty.difficulty && (
            <div class:list={[
              'px-3 py-1 rounded-lg font-semibold text-sm',
              bounty.difficulty === 'Beginner' && 'bg-green-500/20 text-green-400 border border-green-500/40',
              bounty.difficulty === 'Intermediate' && 'bg-yellow-500/20 text-yellow-400 border border-yellow-500/40',
              bounty.difficulty === 'Advanced' && 'bg-red-500/20 text-red-400 border border-red-500/40',
            ]}>
              {bounty.difficulty}
            </div>
          )}
        </div>

        <div class="flex gap-1.5 flex-wrap mb-4">
          {tags.map((tag: string) => (
            <span class="px-2 py-0.5 bg-spark-teal/15 border border-spark-teal/30 rounded text-xs font-mono text-spark-eggshell/90">
              {tag}
            </span>
          ))}
        </div>

        <div class="border-t border-spark-teal/20 pt-4 mb-4">
          <h2 class="font-display text-lg text-spark-chartreuse mb-2">Description</h2>
          <p class="text-spark-eggshell/80 leading-relaxed text-sm">
            {bounty.description}
          </p>
        </div>

        <div class="border-t border-spark-teal/20 pt-4 mb-4">
          <h2 class="font-display text-lg text-spark-chartreuse mb-2">Get Involved</h2>
          <div class="flex flex-wrap gap-3" id="involve-buttons">
            <button
              id="btn-interest"
              data-type="interested"
              class="inline-flex items-center gap-1.5 px-4 py-2 bg-spark-chartreuse text-spark-black rounded-lg font-semibold hover:bg-spark-chartreuse/80 transition-colors text-sm cursor-pointer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              <span>I'm Interested</span>
            </button>
            <button
              id="btn-team"
              data-type="looking-for-team"
              class="inline-flex items-center gap-1.5 px-4 py-2 bg-spark-orange text-spark-black rounded-lg font-semibold hover:bg-spark-orange/80 transition-colors text-sm cursor-pointer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span>Looking for Teammates</span>
            </button>
          </div>
        </div>

        <!-- Email Modal -->
        <div id="email-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
          <div class="bg-spark-black border border-spark-teal/40 rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl">
            <h3 id="modal-title" class="font-display text-xl text-spark-chartreuse mb-2"></h3>
            <p class="text-spark-eggshell/60 text-sm mb-6">Enter your email so the organizers can reach out to you.</p>
            <input
              id="email-input"
              type="email"
              placeholder="you@example.com"
              class="w-full px-4 py-3 bg-spark-black border border-spark-teal/40 rounded-lg text-spark-eggshell font-mono text-base focus:outline-none focus:border-spark-chartreuse transition-colors mb-2"
            />
            <p id="email-error" class="text-red-400 text-sm mb-4 hidden">Please enter a valid email address.</p>
            <div class="flex gap-3 justify-end">
              <button id="modal-cancel" class="px-4 py-2 border border-spark-teal/40 text-spark-eggshell/70 rounded-lg hover:bg-spark-teal/10 transition-colors text-sm">
                Cancel
              </button>
              <button id="modal-submit" class="px-4 py-2 bg-spark-chartreuse text-spark-black rounded-lg font-semibold hover:bg-spark-chartreuse/80 transition-colors text-sm">
                Submit
              </button>
            </div>
          </div>
        </div>

        <div class="border-t border-spark-teal/20 pt-4 mb-4">
          <h2 class="font-display text-lg text-spark-chartreuse mb-2">Project Description</h2>
          {bounty.docLink ? (
            <a
              href={bounty.docLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-4 py-2 bg-spark-chartreuse text-spark-black rounded-lg font-semibold hover:bg-spark-chartreuse/80 transition-colors text-sm"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              View Project Description Doc
            </a>
          ) : (
            <p class="text-spark-eggshell/40 italic text-sm">
              No project description document linked yet.
            </p>
          )}
        </div>
      </div>

      <a
        href="/"
        class="inline-block px-4 py-2 border-2 border-spark-teal text-spark-eggshell rounded-lg font-semibold hover:bg-spark-teal/20 transition-colors text-sm"
      >
        &larr; Back to HackBU OS
      </a>
    </div>
    <script define:vars={{ slug: bounty.slug }}>
      const STORAGE_KEY = 'hackbu-bounty-responses';
      const modal = document.getElementById('email-modal');
      const modalTitle = document.getElementById('modal-title');
      const emailInput = document.getElementById('email-input');
      const emailError = document.getElementById('email-error');
      const btnInterest = document.getElementById('btn-interest');
      const btnTeam = document.getElementById('btn-team');
      let currentType = '';

      function getResponses() {
        try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
        catch { return {}; }
      }

      function saveResponse(bountySlug, type, email) {
        const responses = getResponses();
        if (!responses[bountySlug]) responses[bountySlug] = [];
        responses[bountySlug].push({ type, email, timestamp: new Date().toISOString() });
        localStorage.setItem(STORAGE_KEY, JSON.stringify(responses));
      }

      function hasResponded(bountySlug, type) {
        const responses = getResponses();
        return (responses[bountySlug] || []).some(r => r.type === type);
      }

      function updateButtonState(btn, type, label) {
        if (hasResponded(slug, type)) {
          btn.querySelector('span').textContent = label + ' - Submitted!';
          btn.classList.add('opacity-70');
          btn.disabled = true;
        }
      }

      function openModal(type) {
        currentType = type;
        modalTitle.textContent = type === 'interested'
          ? "I'm Interested"
          : 'Looking for Teammates';
        // Pre-fill with stored email if available
        const storedEmail = localStorage.getItem('hackbu-email') || '';
        emailInput.value = storedEmail;
        emailError.classList.add('hidden');
        modal.classList.remove('hidden');
        emailInput.focus();
      }

      function closeModal() {
        modal.classList.add('hidden');
        currentType = '';
      }

      function submitEmail() {
        const email = emailInput.value.trim();
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          emailError.classList.remove('hidden');
          return;
        }
        localStorage.setItem('hackbu-email', email);
        saveResponse(slug, currentType, email);
        closeModal();
        updateButtonState(btnInterest, 'interested', "I'm Interested");
        updateButtonState(btnTeam, 'looking-for-team', 'Looking for Teammates');
      }

      // Init button states
      updateButtonState(btnInterest, 'interested', "I'm Interested");
      updateButtonState(btnTeam, 'looking-for-team', 'Looking for Teammates');

      btnInterest.addEventListener('click', () => {
        if (!hasResponded(slug, 'interested')) openModal('interested');
      });
      btnTeam.addEventListener('click', () => {
        if (!hasResponded(slug, 'looking-for-team')) openModal('looking-for-team');
      });
      document.getElementById('modal-cancel').addEventListener('click', closeModal);
      document.getElementById('modal-submit').addEventListener('click', submitEmail);
      emailInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') submitEmail();
      });
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });
    </script>
  </body>
</html>
